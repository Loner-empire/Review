# Database
DATABASE_URL=postgresql://user:password@localhost:5432/youth_spark_careers

# JWT
JWT_SECRET=your-very-long-random-secret-here-minimum-32-chars

# S3 Compatible Storage (AWS S3 or Supabase Storage)
STORAGE_BUCKET=youth-spark-uploads
STORAGE_REGION=af-south-1
STORAGE_ACCESS_KEY_ID=your-access-key-id
STORAGE_SECRET_ACCESS_KEY=your-secret-access-key
STORAGE_ENDPOINT=https://s3.af-south-1.amazonaws.com
# If using Supabase storage, set STORAGE_ENDPOINT to your Supabase storage URL

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@youthsparkcareers.co.za

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
